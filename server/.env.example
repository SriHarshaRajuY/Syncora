PORT=4000

# Frontend origin (Vercel) and public app base URL used in emails/manage links
CLIENT_ORIGIN=https://syncora-client.vercel.app
APP_BASE_URL=https://syncora-client.vercel.app

# Database (example placeholders)
DB_HOST=your-db-host
DB_PORT=your-db-port
DB_NAME=railway
DB_USER=root
DB_PASSWORD=your-db-password

DEFAULT_TIMEZONE=Asia/Kolkata

# SMTP (optional; when missing, emails are skipped)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Scheduler Clone <your-email@gmail.com>"

